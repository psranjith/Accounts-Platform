<script src="https://cdn.jsdelivr.net/npm/botframework-webchat@4.16.0/dist/webchat.js" onerror="this.onerror=null;this.src='https://unpkg.com/botframework-webchat@4.16.0/dist/webchat.js';"></script>
<script>
  (function () {
    // ---- filtering ----
    var f  = document.getElementById('agFilter');
    var v  = document.getElementById('agVendor');
    var c  = document.getElementById('agCategory');
    function apply() {
      var q = (f.value || '').toLowerCase();
      document.querySelectorAll('.ag-card').forEach(function (card) {
        var text = card.textContent.toLowerCase();
        var passQ = !q || text.indexOf(q) !== -1;
        var passV = !v.value || card.getAttribute('data-vendor') === v.value;
        var passC = !c.value || card.getAttribute('data-cat')    === c.value;
        card.style.display = (passQ && passV && passC) ? '' : 'none';
      });
    }
    [f, v, c].forEach(function (el) { el && el.addEventListener('input', apply); });
    if (v) v.addEventListener('change', apply);
    if (c) c.addEventListener('change', apply);

    // ---- enable / configure stubs ----
    document.querySelectorAll('[data-act]').forEach(function (btn) {
      var act   = btn.getAttribute('data-act');
      if (act !== 'enable' && act !== 'configure') return;
      btn.addEventListener('click', function () {
        var agent = btn.getAttribute('data-agent');
        if (act === 'enable') {
          alert('Enable "' + agent + '" for this client (stub). Will be wired to Flow_ManageAgents in production.');
        } else {
          alert('Configure "' + agent + '" (stub). Will open Copilot Studio in production.');
        }
      });
    });

    // ---- launch custom agent (Copilot Studio) in-page panel ----
    var panel = document.getElementById('agChatPanel');
    var titleEl = document.getElementById('agChatTitle');
    var chatEl = document.getElementById('ag-copilot-webchat');
    var diagEl = document.getElementById('ag-copilot-diag');
    var booted = false;

    function showDiag(level, html) { diagEl.hidden = false; diagEl.className = 'copilot-diag copilot-diag-' + level; diagEl.innerHTML = html; }

    document.getElementById('agChatClose').addEventListener('click', function () {
      panel.hidden = true;
    });

    document.querySelectorAll('[data-act="launch"]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var key = btn.getAttribute('data-agent');
        titleEl.textContent = (btn.closest('.ag-card').querySelector('strong').textContent) || ('Agent ' + key);
        panel.hidden = false;
        if (booted) return;
        var cfg = (window.ADP_AUTH && window.ADP_AUTH.copilot) || null;
        if (!cfg || !cfg.conversationsUrl) {
          showDiag('warn', '<strong>Custom agent not configured.</strong> Add a <code>copilot</code> section to <code>preview/auth-config.js</code>.');
          return;
        }
        if (!window.adpGraph || !window.adpGraph.isSignedIn()) {
          showDiag('info', '<strong>Sign in to Microsoft 365</strong> (top right) to start the agent.');
          return;
        }
        bootWebChat(cfg);
      });
    });

    async function bootWebChat(cfg) {
      try {
        showDiag('info', '<strong>Loading chat client&hellip;</strong>');
        // Acquire a Power Platform delegated token for the user.
        var token = await window.adpGraph.getTokenFor(cfg.scopes);
        var r = await fetch(cfg.conversationsUrl, {
          method: 'POST',
          headers: { Authorization: 'Bearer ' + token, 'Content-Type': 'application/json' },
          body: '{}'
        });
        if (!r.ok) throw new Error('conversationsUrl ' + r.status);
        var j = await r.json();
        if (!window.WebChat) throw new Error('Bot Framework Web Chat failed to load.');
        window.WebChat.renderWebChat({
          directLine: window.WebChat.createDirectLine({ token: j.token, streamUrl: j.streamUrl }),
          userID: (window.adpGraph.account() || {}).localAccountId || 'preview-user',
          locale: 'en-IN'
        }, document.getElementById('ag-copilot-webchat'));
        diagEl.hidden = true;
        booted = true;
      } catch (err) {
        showDiag('error', '<strong>Could not start agent:</strong> ' + (err && err.message ? err.message : String(err)));
      }
    }
  })();
</script>

