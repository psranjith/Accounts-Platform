{% comment %} Smart Agent hero — merged from former /assistant page. {% endcomment %}
<section class="sa-hero">
  <div class="sa-hero-text">
    <span class="sa-hero-eyebrow">Featured</span>
    <h2>Smart Agent</h2>
    <p>Ask anything about your engagements, GST positions, Tally data or client policies. Smart Agent grounds answers in your firm's catalog and the active client's documents.</p>
    <div class="sa-hero-actions">
      <button class="btn btn-primary" type="button" id="saHeroLaunch">Open Smart Agent</button>
      <a class="btn btn-link" href="#smart-agent">Learn more</a>
    </div>
  </div>
  <div class="sa-hero-visual" aria-hidden="true">
    <div class="sa-bubble sa-b1">"Summarise GSTR-3B for Acme last quarter."</div>
    <div class="sa-bubble sa-b2">"Open tasks closing this week?"</div>
    <div class="sa-bubble sa-b3">"Draft reply to GSTN notice for Beta."</div>
  </div>
</section>

<style>
  .sa-hero { display:grid; grid-template-columns:1.4fr 1fr; gap:18px; background:linear-gradient(135deg,#00395E 0%,#00638a 60%,#00A8E8 100%); color:#fff; border-radius:12px; padding:22px 26px; margin-bottom:18px; }
  .sa-hero-eyebrow { display:inline-block; background:rgba(255,255,255,.18); padding:2px 10px; border-radius:999px; font-size:11px; letter-spacing:.06em; text-transform:uppercase; }
  .sa-hero h2 { margin:8px 0 6px; font-size:28px; }
  .sa-hero p { margin:0 0 12px; opacity:.92; max-width:540px; }
  .sa-hero-actions { display:flex; gap:10px; align-items:center; }
  .sa-hero-actions .btn-primary { background:#fff; color:#00395E; border:0; }
  .sa-hero-actions .btn-link { color:#fff; text-decoration:underline; }
  .sa-hero-visual { position:relative; min-height:120px; }
  .sa-bubble { position:absolute; background:rgba(255,255,255,.16); padding:6px 12px; border-radius:14px; font-size:13px; backdrop-filter:blur(4px); }
  .sa-b1 { top:6px;  left:0;   } .sa-b2 { top:46px; left:60px; } .sa-b3 { top:86px; left:18px; }
  @media (max-width: 760px) { .sa-hero { grid-template-columns:1fr; } .sa-hero-visual { display:none; } }
</style>

<script>
  document.getElementById('saHeroLaunch') && document.getElementById('saHeroLaunch').addEventListener('click', function () {
    var el = document.querySelector('[data-key="quote-prep"]');
    if (el) { el.scrollIntoView({ behavior:'smooth', block:'center' }); el.style.outline = '2px solid #00A8E8'; setTimeout(function(){ el.style.outline=''; }, 1800); }
  });
</script>

{% comment %}
  Agents catalog & launcher
  -------------------------
  Single page for all AI agents available to the platform:
   - Microsoft built-in agents (Analyst, Researcher, Sales, Facilitator,
     Skills, etc.) - opened in M365 Copilot via deep link.
   - Custom Copilot Studio agents (Smartsoft Quote Prep, GST Helper, Audit
     Reviewer, Tally Q&A) - embedded in-page using Bot Framework Web Chat
     against a Direct Line token obtained from the agent's conversationsUrl
     (same pattern as the Smart Agent page).

  Microsoft built-in agents require an eligible Microsoft 365 Copilot
  licence on the signed-in user; custom agents only need access to the
  Copilot Studio agent.

  Role-aware:
    Accountant - can enable/disable agents per client and across portfolio.
    Admin      - can enable/disable agents for own company.
    Client     - read-only list of enabled agents.
{% endcomment %}

{% assign role_norm = adp_role | downcase %}
{% assign is_accountant = false %}
{% assign is_admin      = false %}
{% if role_norm contains 'accountant' %}{% assign is_accountant = true %}{% endif %}
{% if role_norm contains 'admin'      %}{% assign is_admin      = true %}{% endif %}
{% assign can_manage = false %}
{% if is_accountant or is_admin %}{% assign can_manage = true %}{% endif %}

