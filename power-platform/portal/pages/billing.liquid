<script>
(function () {
  function activate(hash) {
    var name = (hash || '').replace('#','') || 'plans';
    document.querySelectorAll('.bl-tab').forEach(function(a){ a.classList.toggle('is-active', a.getAttribute('data-tab') === name); });
    document.querySelectorAll('.bl-panel').forEach(function(p){ p.classList.toggle('is-active', p.getAttribute('data-panel') === name); });
  }
  document.querySelectorAll('.bl-tab').forEach(function(a){
    a.addEventListener('click', function(e){ e.preventDefault(); history.replaceState(null,'',a.getAttribute('href')); activate(a.getAttribute('href')); });
  });
  activate(location.hash);
})();
</script>

<style>
  .bl-tabs { display:flex; gap:2px; border-bottom:1px solid #e1e6ec; margin-bottom:14px; flex-wrap:wrap; }
  .bl-tab { padding:8px 14px; text-decoration:none; color:#6b7280; font-weight:600; font-size:13px; border-bottom:2px solid transparent; }
  .bl-tab.is-active { color:#00395E; border-bottom-color:#00A8E8; }
  .bl-panel { display:none; } .bl-panel.is-active { display:block; }
  .bl-plans { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:14px; }
  .bl-plan { background:#fff; border:1px solid #e1e6ec; border-radius:10px; padding:16px; position:relative; }
  .bl-plan-featured { border-color:#00A8E8; box-shadow:0 4px 14px rgba(0,168,232,.18); }
  .bl-plan header h3 { margin:0; color:#00395E; }
  .bl-price { font-size:24px; font-weight:700; color:#00395E; margin:6px 0 4px; }
  .bl-price small { font-size:12px; color:#6b7280; font-weight:500; }
  .bl-badge { position:absolute; top:10px; right:10px; background:#00A8E8; color:#fff; font-size:10px; padding:2px 8px; border-radius:999px; font-weight:600; letter-spacing:.04em; text-transform:uppercase; }
  .bl-plan ul { padding-left:18px; font-size:13px; color:#374151; }
  .bl-plan ul li { margin:4px 0; }
  .bl-active { display:grid; grid-template-columns:2fr 1fr; gap:14px; }
  @media (max-width: 760px) { .bl-active { grid-template-columns:1fr; } }
  .bl-active-card, .bl-active-side, .bl-pay-card { background:#fff; border:1px solid #e1e6ec; border-radius:10px; padding:14px; }
  .bl-active-card h3 { margin:8px 0 2px; color:#00395E; }
  .badge { padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; }
  .badge-active { background:#d1f3e0; color:#0a6b3a; }
  .bl-active-meta { list-style:none; padding:0; margin:12px 0 0; }
  .bl-active-meta li { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #eef2f7; font-size:13px; }
  .bl-active-meta li:last-child { border-bottom:0; }
  .bl-active-meta span { color:#6b7280; }
  .bl-active-meta strong { color:#00395E; }
  .bl-active-actions { margin-top:10px; display:flex; gap:8px; }
  .bl-usage { list-style:none; padding:0; margin:0; }
  .bl-usage li { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #eef2f7; font-size:13px; }
  .bl-usage li:last-child { border-bottom:0; }
  .bl-usage span { color:#6b7280; } .bl-usage strong { color:#00395E; }
  .bl-pay { display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:12px; }
  .bl-pay-card strong { color:#00395E; display:block; margin-bottom:4px; }
  .muted { color:#6b7280; }
  .small { font-size:12px; }
</style>

