  .adp-inbox .adp-endpoint-chip.ch-email { background: #1d4ed8; }
  .adp-inbox .adp-endpoint-chip.ch-wa    { background: #25d366; }
  .adp-inbox .adp-endpoint-chip.ch-tg    { background: #0088cc; }
  .adp-inbox .adp-endpoint-chip.ch-sp    { background: #0f766e; }
