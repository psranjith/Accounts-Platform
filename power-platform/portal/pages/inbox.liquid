  .adp-inbox .adp-company-head { display: flex; justify-content: space-between; align-items: center; }
  .adp-inbox .adp-company-head strong { color: #00395E; font-size: 14px; }
  .adp-inbox .adp-pill { background: #b42318; color: #fff; border-radius: 999px; padding: 0 6px; font-size: 11px; font-weight: 700; }
  .adp-inbox .adp-company-chips { display: flex; gap: 4px; margin-top: 2px; }
  .adp-inbox .adp-channel-chip { display: inline-flex; align-items: center; justify-content: center; min-width: 22px; height: 18px; padding: 0 6px; border-radius: 999px; font-size: 11px; color: #fff; }
  .adp-inbox .adp-channel-chip.ch-email   { background: #1d4ed8; }
  .adp-inbox .adp-channel-chip.ch-whatsapp,
  .adp-inbox .adp-channel-chip.ch-wa      { background: #25d366; }
  .adp-inbox .adp-channel-chip.ch-telegram,
  .adp-inbox .adp-channel-chip.ch-tg      { background: #0088cc; }
  .adp-inbox .adp-channel-chip.ch-sharepoint,
  .adp-inbox .adp-channel-chip.ch-sp      { background: #0f766e; }

  .adp-inbox .adp-avatar { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 999px; background: #00395E; color: #fff; font-size: 11px; font-weight: 700; flex: 0 0 auto; }
