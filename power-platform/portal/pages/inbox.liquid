  .adp-inbox .adp-rail-tab.is-active { background: #fff; border-color: #d6dde6; color: #00395E; }
  .adp-inbox .adp-company-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; max-height: 520px; overflow-y: auto; }
  .adp-inbox .adp-company { display: grid; grid-template-columns: 32px 1fr; gap: 8px; padding: 8px; border-radius: 6px; cursor: pointer; align-items: center; }
