  .adp-inbox .adp-meta { color: #6b7280; margin: 4px 0 16px; font-size: 14px; }
  .adp-inbox .muted { color: #6b7280; }

  .adp-inbox .adp-kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; margin-bottom: 14px; }
