  .adp-inbox .adp-toolbar { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .adp-inbox .adp-pill-row { display: flex; gap: 4px; flex-wrap: wrap; }
  .adp-inbox .adp-pill { background: #f7f9fc; border: 1px solid #d6dde6; color: #00395E; padding: 4px 10px; border-radius: 999px; cursor: pointer; font-size: 12px; }
