{% include 'adp-user-context' %}
{% assign nav_key = 'service' %}
{% assign page_title = 'Service Delivery' %}
{% assign breadcrumbs = 'Dashboard|/dashboard · Service Delivery' %}
{% include 'adp-shell-open' %}
{% comment %}
  Service Delivery & Process Platform
  -----------------------------------
  A separate page that surfaces the firm's productised services (GST return,
  monthly book closure, payroll, audit prep, etc.), tracks active engagements
  per client through a Kanban pipeline and per-task checklists, and surfaces
  SLA / throughput KPIs.

  Role-aware:
   - Accountant : portfolio across all client companies (full board + onboard form)
   - Admin      : engagements for own company (board + checklist, no onboard)
   - Client     : read-only view of own engagements + ETA

  Backing Dataverse tables (to be created in solution/src):
   - adp_serviceprocess : catalog of standardised processes (id, name, sla days, owner_role, default_tasks)
   - adp_engagement     : an instance of a process running for a company (companyid, processid, stage, owner, startdate, duedate, status)
   - adp_engagementtask : per-engagement checklist row (engagementid, name, owner, due, status)

  The preview harness stubs these tables; see preview/preview.js.
{% endcomment %}

{% assign role_norm = adp_role | downcase %}
{% assign is_accountant = false %}
{% assign is_admin      = false %}
{% if role_norm contains 'accountant' %}{% assign is_accountant = true %}{% endif %}
{% if role_norm contains 'admin'      %}{% assign is_admin      = true %}{% endif %}
{% assign can_manage = false %}
{% if is_accountant or is_admin %}{% assign can_manage = true %}{% endif %}

<section class="service-delivery">
  <header class="sd-header">
    <h2>Service Delivery &amp; Process Platform</h2>
    <p class="sd-meta">
      {% if is_accountant %}
        Signed in as <strong>Accountant</strong> &middot; portfolio across all clients
      {% else %}
        Company <strong>{{ adp_companyid | default: '(none)' }}</strong> &middot; Role <strong>{{ adp_role | default: 'Client' }}</strong>
      {% endif %}
    </p>
  </header>

  {% fetchxml engagements_query %}
  <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="200">
    <entity name="adp_engagement">
      <attribute name="adp_engagementid" />
      <attribute name="adp_companyid" />
      <attribute name="adp_processid" />
      <attribute name="adp_processname" />
      <attribute name="adp_stage" />
      <attribute name="adp_status" />
      <attribute name="adp_ownername" />
      <attribute name="adp_startdate" />
      <attribute name="adp_duedate" />
      <attribute name="adp_progress" />
      {% unless is_accountant %}
      <filter>
        <condition attribute="adp_companyid" operator="eq" value="{{ adp_companyid }}" />
      </filter>
      {% endunless %}
      <order attribute="adp_duedate" descending="false" />
    </entity>
  </fetch>
  {% endfetchxml %}

  {% assign engagements = engagements_query.results.entities %}

  {% comment %} -------- KPI cards -------- {% endcomment %}
  {% assign open_count   = 0 %}
  {% assign at_risk      = 0 %}
  {% assign done_month   = 0 %}
  {% assign owners       = '' %}
  {% for e in engagements %}
    {% if e.adp_stage.label != 'Delivered' and e.adp_stage.label != 'Cancelled' %}
      {% assign open_count = open_count | plus: 1 %}
    {% endif %}
    {% if e.adp_status.label == 'At Risk' or e.adp_status.label == 'Overdue' %}
      {% assign at_risk = at_risk | plus: 1 %}
    {% endif %}
    {% if e.adp_stage.label == 'Delivered' %}
      {% assign done_month = done_month | plus: 1 %}
    {% endif %}
  {% endfor %}

  <div class="kpi-grid">
    <div class="kpi"><span class="kpi-label">Open engagements</span><strong>{{ open_count }}</strong></div>
    <div class="kpi kpi-warn"><span class="kpi-label">At risk / overdue</span><strong>{{ at_risk }}</strong></div>
    <div class="kpi"><span class="kpi-label">Unassigned tasks</span><strong id="sdUnassignedKpi">0</strong></div>
    <div class="kpi"><span class="kpi-label">Delivered (this period)</span><strong>{{ done_month }}</strong></div>
    <div class="kpi"><span class="kpi-label">Avg cycle (days)</span><strong>4.6</strong></div>
    <div class="kpi"><span class="kpi-label">On-time %</span><strong>92%</strong></div>
  </div>

  {% comment %} -------- Staff & schedule data (used by JS and below) -------- {% endcomment %}
  {% fetchxml staff_query %}
  <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="50">
    <entity name="adp_staff">
      <attribute name="adp_staffid" />
      <attribute name="adp_name" />
      <attribute name="adp_role" />
      <attribute name="adp_initials" />
      <attribute name="adp_opentasks" />
      <attribute name="adp_capacity" />
      <attribute name="adp_color" />
      <order attribute="adp_name" />
    </entity>
  </fetch>
  {% endfetchxml %}
  {% assign staff = staff_query.results.entities %}

  {% fetchxml schedule_query %}
  <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="50">
    <entity name="adp_schedule">
      <attribute name="adp_scheduleid" />
      <attribute name="adp_processid" />
      <attribute name="adp_processname" />
      <attribute name="adp_companyid" />
      <attribute name="adp_recurrence" />
      <attribute name="adp_nextrun" />
      <attribute name="adp_assigneeid" />
      <attribute name="adp_assigneename" />
      <attribute name="adp_reminderdays" />
      <attribute name="adp_reminderon" />
      <attribute name="adp_status" />
      {% unless is_accountant %}
      <filter>
        <condition attribute="adp_companyid" operator="eq" value="{{ adp_companyid }}" />
      </filter>
      {% endunless %}
      <order attribute="adp_nextrun" descending="false" />
    </entity>
  </fetch>
  {% endfetchxml %}
  {% assign schedules = schedule_query.results.entities %}

  {% fetchxml tasks_query %}
  <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="200">
    <entity name="adp_engagementtask">
      <attribute name="adp_taskid" />
      <attribute name="adp_engagementid" />
      <attribute name="adp_name" />
      <attribute name="adp_assigneeid" />
      <attribute name="adp_assigneename" />
      <attribute name="adp_due" />
      <attribute name="adp_status" />
      <attribute name="adp_reminderon" />
      <order attribute="adp_due" descending="false" />
    </entity>
  </fetch>
  {% endfetchxml %}
  {% assign tasks = tasks_query.results.entities %}

  {% fetchxml activity_query %}
  <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="200">
    <entity name="adp_activity">
      <attribute name="adp_activityid" />
      <attribute name="adp_engagementid" />
      <attribute name="adp_type" />
      <attribute name="adp_actor" />
      <attribute name="adp_ts" />
      <attribute name="adp_text" />
      <order attribute="adp_ts" descending="true" />
    </entity>
  </fetch>
  {% endfetchxml %}
  {% assign activity = activity_query.results.entities %}

  {% comment %} -------- Active schedule cards (process scheduling + reminders) -------- {% endcomment %}
  {% if schedules.size > 0 %}
  <div class="sd-schedule-wrap">
    <div class="sd-section-head">
      <h3>Active schedules &amp; reminders</h3>
      {% if can_manage %}<button type="button" class="btn btn-link" id="sdNewSchedule">+ New schedule</button>{% endif %}
    </div>
    <div class="sd-schedule-strip" id="sdScheduleStrip">
      {% for s in schedules %}
        <article class="sd-schedule-card" data-schedule="{{ s.adp_scheduleid }}" data-nextrun="{{ s.adp_nextrun }}" data-process="{{ s.adp_processid }}" data-assignee="{{ s.adp_assigneeid }}">
          <header class="sd-sc-head">
            <span class="sd-sc-title">{{ s.adp_processname }}</span>
            <button type="button" class="sd-bell {% if s.adp_reminderon %}on{% endif %}" data-act="reminder" data-schedule="{{ s.adp_scheduleid }}" title="Toggle reminder" aria-pressed="{{ s.adp_reminderon }}">
              <span aria-hidden="true">{% if s.adp_reminderon %}&#128276;{% else %}&#128277;{% endif %}</span>
            </button>
          </header>
          {% if is_accountant %}<div class="sd-sc-company">{{ s.adp_companyid.name | default: s.adp_companyid.id }}</div>{% endif %}
          <div class="sd-sc-meta">
            <span class="sd-sc-recur">{{ s.adp_recurrence }}</span>
            <span class="sd-countdown" data-countdown="{{ s.adp_nextrun }}">{{ s.adp_nextrun }}</span>
          </div>
          <div class="sd-sc-assignee">
            {% for st in staff %}{% if st.adp_staffid == s.adp_assigneeid %}
              <span class="sd-avatar" style="background:{{ st.adp_color }}">{{ st.adp_initials }}</span>
              <span class="sd-assignee-name">{{ st.adp_name }}</span>
            {% endif %}{% endfor %}
            {% if s.adp_assigneeid == '' or s.adp_assigneeid == nil %}
              <span class="sd-avatar sd-avatar-unassigned">?</span>
              <span class="sd-assignee-name muted">Unassigned</span>
            {% endif %}
          </div>
          <div class="sd-sc-actions">
            <button type="button" class="btn btn-link" data-act="run-now"  data-schedule="{{ s.adp_scheduleid }}" data-process="{{ s.adp_processid }}" data-process-name="{{ s.adp_processname }}">Run now</button>
            <button type="button" class="btn btn-link" data-act="snooze"   data-schedule="{{ s.adp_scheduleid }}">Snooze</button>
            {% if can_manage %}<button type="button" class="btn btn-link" data-act="reassign" data-schedule="{{ s.adp_scheduleid }}">Reassign</button>{% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% comment %} -------- Team workload + My / Unassigned tasks -------- {% endcomment %}
  {% if can_manage %}
  <div class="sd-team-wrap">
    <div class="sd-team-panel">
      <div class="sd-team-col">
        <h3>Team workload</h3>
        <ul class="sd-staff-list">
          {% for st in staff %}
            {% assign load_pct = st.adp_opentasks | times: 100 | divided_by: st.adp_capacity %}
            <li class="sd-staff" data-staff="{{ st.adp_staffid }}">
              <span class="sd-avatar" style="background:{{ st.adp_color }}">{{ st.adp_initials }}</span>
              <div class="sd-staff-body">
                <div class="sd-staff-head">
                  <strong>{{ st.adp_name }}</strong>
                  <span class="muted">{{ st.adp_opentasks }} / {{ st.adp_capacity }}</span>
                </div>
                <div class="sd-staff-role muted">{{ st.adp_role }}</div>
                <div class="sd-capacity-bar"><span style="width:{{ load_pct }}%" data-load="{{ load_pct }}"></span></div>
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
      <div class="sd-team-col">
        <h3>Unassigned &amp; due-soon tasks</h3>
        <ul class="sd-task-list" id="sdTaskList">
          {% for t in tasks %}
            {% if t.adp_status.label != 'Done' %}
              {% assign show_row = false %}
              {% if t.adp_assigneeid == '' or t.adp_assigneeid == nil %}{% assign show_row = true %}{% endif %}
              {% if t.adp_status.label == 'In Progress' %}{% assign show_row = true %}{% endif %}
              {% if show_row %}
                <li class="sd-task {% if t.adp_assigneeid == '' or t.adp_assigneeid == nil %}is-unassigned{% endif %}" data-task="{{ t.adp_taskid }}" data-eng="{{ t.adp_engagementid }}">
                  <div class="sd-task-main">
                    <div class="sd-task-name">{{ t.adp_name }}</div>
                    <div class="sd-task-sub muted">
                      <a href="#" class="sd-open" data-eng="{{ t.adp_engagementid }}">{{ t.adp_engagementid }}</a>
                      &middot; due {{ t.adp_due }}
                      &middot; <span class="badge badge-{{ t.adp_status.label | downcase | replace: ' ', '-' }}">{{ t.adp_status.label }}</span>
                    </div>
                  </div>
                  <select class="sd-assign-select" data-task="{{ t.adp_taskid }}" aria-label="Assign task">
                    <option value="">— Assign —</option>
                    {% for st in staff %}
                      <option value="{{ st.adp_staffid }}" data-name="{{ st.adp_name }}" {% if st.adp_staffid == t.adp_assigneeid %}selected{% endif %}>{{ st.adp_name }}</option>
                    {% endfor %}
                  </select>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
  {% endif %}

  {% comment %} -------- Pipeline (kanban) -------- {% endcomment %}
  <details class="sd-pipeline-wrap" open>
    <summary><h3 style="display:inline-block;margin:0">Pipeline</h3></summary>
    <div class="sd-pipeline" id="sdPipeline">
      {% assign stages = 'Intake,In Progress,Review,Approved,Delivered' | split: ',' %}
      {% for stage in stages %}
        <div class="sd-col" data-stage="{{ stage }}">
          <div class="sd-col-head"><strong>{{ stage }}</strong><span class="sd-count" data-stage-count="{{ stage }}">0</span></div>
          <div class="sd-col-body">
            {% for e in engagements %}
              {% if e.adp_stage.label == stage %}
                {% assign comment_count = 0 %}
                {% for a in activity %}{% if a.adp_engagementid == e.adp_engagementid and a.adp_type.label == 'comment' %}{% assign comment_count = comment_count | plus: 1 %}{% endif %}{% endfor %}
                {% assign owner_initials = e.adp_ownername | split: ' ' | first | slice: 0, 1 %}
                <div class="sd-card status-{{ e.adp_status.label | downcase | replace: ' ', '-' }}"
                     data-eng="{{ e.adp_engagementid }}"
                     data-company="{{ e.adp_companyid.id }}">
                  <div class="sd-card-title">{{ e.adp_processname }}</div>
                  <div class="sd-card-sub">
                    {% if is_accountant %}{{ e.adp_companyid.name | default: e.adp_companyid.id }} &middot; {% endif %}
                    {{ e.adp_ownername }}
                  </div>
                  <div class="sd-card-foot">
                    <span class="sd-due">Due {{ e.adp_duedate }}</span>
                    <span class="sd-card-chips">
                      {% if comment_count > 0 %}<span class="sd-chip" title="Comments">&#128172; {{ comment_count }}</span>{% endif %}
                      <span class="sd-progress"><span style="width:{{ e.adp_progress | default: 0 }}%"></span></span>
                    </span>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </details>

  {% comment %} -------- Engagements table -------- {% endcomment %}
  <div class="sd-table-wrap">
    <h3>All engagements</h3>
    <div class="sd-toolbar">
      <input type="search" id="sdFilter" placeholder="Filter by company, service, owner..." />
      <select id="sdStage">
        <option value="">All stages</option>
        {% for stage in stages %}<option>{{ stage }}</option>{% endfor %}
        <option>Cancelled</option>
      </select>
      <select id="sdStatus">
        <option value="">All statuses</option>
        <option>On Track</option>
        <option>At Risk</option>
        <option>Overdue</option>
        <option>Blocked</option>
        <option>Complete</option>
      </select>
      {% if can_manage %}<button class="btn btn-primary" type="button" id="sdNew">+ New engagement</button>{% endif %}
    </div>
    {% if engagements.size == 0 %}
      <div class="placeholder">No engagements yet.</div>
    {% else %}
      <table class="sd-table">
        <thead>
          <tr>
            {% if is_accountant %}<th>Company</th>{% endif %}
            <th>Service</th>
            <th>Stage</th>
            <th>Status</th>
            <th>Assignee</th>
            <th>Started</th>
            <th>Due</th>
            <th>Progress</th>
            {% if can_manage %}<th></th>{% endif %}
          </tr>
        </thead>
        <tbody>
          {% for e in engagements %}
          <tr data-stage="{{ e.adp_stage.label }}" data-status="{{ e.adp_status.label }}" data-eng="{{ e.adp_engagementid }}">
            {% if is_accountant %}<td><a href="/companies?id={{ e.adp_companyid.id }}">{{ e.adp_companyid.name | default: e.adp_companyid.id }}</a></td>{% endif %}
            <td><a href="#" class="sd-open" data-eng="{{ e.adp_engagementid }}">{{ e.adp_processname }}</a></td>
            <td><span class="badge badge-stage">{{ e.adp_stage.label }}</span></td>
            <td><span class="badge badge-{{ e.adp_status.label | downcase | replace: ' ', '-' }}">{{ e.adp_status.label }}</span></td>
            <td class="sd-assignee-cell">
              {% if can_manage %}
                <select class="sd-row-assign" data-eng="{{ e.adp_engagementid }}" aria-label="Assignee">
                  {% for st in staff %}
                    <option value="{{ st.adp_staffid }}" {% if st.adp_name == e.adp_ownername %}selected{% endif %}>{{ st.adp_name }}</option>
                  {% endfor %}
                </select>
              {% else %}
                {{ e.adp_ownername }}
              {% endif %}
            </td>
            <td>{{ e.adp_startdate }}</td>
            <td>{{ e.adp_duedate }}</td>
            <td><div class="sd-progress-bar"><span style="width:{{ e.adp_progress | default: 0 }}%"></span></div></td>
            {% if can_manage %}
            <td class="actions">
              <button class="btn btn-link" type="button" data-act="open"     data-eng="{{ e.adp_engagementid }}">Open</button>
              <button class="btn btn-link" type="button" data-act="advance"  data-eng="{{ e.adp_engagementid }}">Advance</button>
              <button class="btn btn-link text-danger" type="button" data-act="cancel" data-eng="{{ e.adp_engagementid }}">Cancel</button>
            </td>
            {% endif %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

  {% comment %} -------- Engagement detail drawer (tabs: Checklist / Activity / Schedule) -------- {% endcomment %}
  <aside id="sdDrawer" class="sd-drawer" hidden>
    <div class="sd-drawer-head">
      <strong id="sdDrawerTitle">Engagement</strong>
      <button type="button" class="btn btn-link" id="sdDrawerClose">Close</button>
    </div>
    <nav class="sd-tabs" role="tablist">
      <button type="button" class="sd-tab is-active" data-tab="checklist" role="tab" aria-selected="true">Checklist</button>
      <button type="button" class="sd-tab"           data-tab="activity"  role="tab" aria-selected="false">Activity <span class="sd-tab-badge" id="sdActivityBadge">0</span></button>
      <button type="button" class="sd-tab"           data-tab="schedule"  role="tab" aria-selected="false">Schedule</button>
    </nav>
    <div class="sd-drawer-body">
      <section class="sd-tab-panel is-active" data-panel="checklist" id="sdPanelChecklist">Loading&hellip;</section>
      <section class="sd-tab-panel"           data-panel="activity"  id="sdPanelActivity"></section>
      <section class="sd-tab-panel"           data-panel="schedule"  id="sdPanelSchedule"></section>
    </div>
  </aside>

  {% comment %} -------- JSON data island consumed by the page script -------- {% endcomment %}
  <script type="application/json" id="sdStaffData">
    [{% for st in staff %}{"id":"{{ st.adp_staffid }}","name":"{{ st.adp_name }}","role":"{{ st.adp_role }}","initials":"{{ st.adp_initials }}","color":"{{ st.adp_color }}","openTasks":{{ st.adp_opentasks }},"capacity":{{ st.adp_capacity }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
  </script>
  <script type="application/json" id="sdTaskData">
    [{% for t in tasks %}{"id":"{{ t.adp_taskid }}","engagementId":"{{ t.adp_engagementid }}","name":"{{ t.adp_name | replace: '"', '\"' }}","assigneeId":"{{ t.adp_assigneeid }}","assigneeName":"{{ t.adp_assigneename | replace: '"', '\"' }}","due":"{{ t.adp_due }}","status":"{{ t.adp_status.label }}","reminderOn":{% if t.adp_reminderon %}true{% else %}false{% endif %}}{% unless forloop.last %},{% endunless %}{% endfor %}]
  </script>
  <script type="application/json" id="sdActivityData">
    [{% for a in activity %}{"id":"{{ a.adp_activityid }}","engagementId":"{{ a.adp_engagementid }}","type":"{{ a.adp_type.label }}","actor":"{{ a.adp_actor | replace: '"', '\"' }}","ts":"{{ a.adp_ts }}","text":"{{ a.adp_text | replace: '"', '\"' | replace: '
', ' ' }}"}{% unless forloop.last %},{% endunless %}{% endfor %}]
  </script>
  <script type="application/json" id="sdScheduleData">
    [{% for s in schedules %}{"id":"{{ s.adp_scheduleid }}","processId":"{{ s.adp_processid }}","processName":"{{ s.adp_processname }}","recurrence":"{{ s.adp_recurrence }}","nextRun":"{{ s.adp_nextrun }}","assigneeId":"{{ s.adp_assigneeid }}","assigneeName":"{{ s.adp_assigneename }}","reminderDays":{{ s.adp_reminderdays }},"reminderOn":{% if s.adp_reminderon %}true{% else %}false{% endif %}}{% unless forloop.last %},{% endunless %}{% endfor %}]
  </script>

  {% comment %} -------- Service catalog -------- {% endcomment %}
  {% fetchxml catalog_query %}
  <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="50">
    <entity name="adp_serviceprocess">
      <attribute name="adp_serviceprocessid" />
      <attribute name="adp_name" />
      <attribute name="adp_description" />
      <attribute name="adp_sladays" />
      <attribute name="adp_ownerrole" />
      <attribute name="adp_taskcount" />
      <attribute name="adp_active" />
      <order attribute="adp_name" />
    </entity>
  </fetch>
  {% endfetchxml %}

  <details class="sd-catalog-wrap">
    <summary><h3 style="display:inline-block;margin:0">Service catalog</h3></summary>
    <div class="sd-catalog">
      {% for p in catalog_query.results.entities %}
        <article class="sd-process">
          <h4>{{ p.adp_name }}</h4>
          <p class="muted">{{ p.adp_description }}</p>
          <ul class="sd-process-meta">
            <li>SLA: <strong>{{ p.adp_sladays }} days</strong></li>
            <li>Default owner: <strong>{{ p.adp_ownerrole }}</strong></li>
            <li>Tasks: <strong>{{ p.adp_taskcount }}</strong></li>
          </ul>
          {% if can_manage %}
            <button type="button" class="btn btn-default sd-start" data-process="{{ p.adp_serviceprocessid }}" data-process-name="{{ p.adp_name }}">Start engagement</button>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </details>

  {% comment %} -------- New / Start engagement modal -------- {% endcomment %}
  <div id="sdModal" class="sd-modal" hidden>
    <div class="sd-modal-card">
      <h3>Start new engagement</h3>
      <form id="sdModalForm" method="post" action="/_api/cloudflow/v1.0/trigger/Flow_StartEngagement">
        <label>Service
          <select name="processId" id="sdModalProcess">
            {% for p in catalog_query.results.entities %}
              <option value="{{ p.adp_serviceprocessid }}">{{ p.adp_name }}</option>
            {% endfor %}
          </select>
        </label>
        {% if is_accountant %}
        <label>Client company
          <select name="companyId">
            <option value="00000000-0000-0000-0000-000000000001">Acme Traders Pvt Ltd</option>
            <option value="00000000-0000-0000-0000-000000000002">Beta Industries</option>
            <option value="00000000-0000-0000-0000-000000000003">Gamma Foods LLP</option>
            <option value="00000000-0000-0000-0000-000000000004">Delta Logistics</option>
            <option value="00000000-0000-0000-0000-000000000005">Epsilon Retail</option>
          </select>
        </label>
        {% else %}
          <input type="hidden" name="companyId" value="{{ adp_companyid }}" />
        {% endif %}
        <label>Owner
          <input type="text" name="owner" value="{{ user.fullname }}" />
        </label>
        <label>Due date
          <input type="date" name="dueDate" />
        </label>
        <label>Notes
          <textarea name="notes" rows="3"></textarea>
        </label>
        <div class="sd-modal-actions">
          <button type="button" class="btn btn-default" id="sdModalCancel">Cancel</button>
          <button type="submit" class="btn btn-primary">Start</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    (function () {
      // ---- Data islands ------------------------------------------------------
      function parseJSON(id) {
        var el = document.getElementById(id);
        try { return el ? JSON.parse(el.textContent || '[]') : []; } catch (e) { return []; }
      }
      var STAFF    = parseJSON('sdStaffData');
      var TASKS    = parseJSON('sdTaskData');
      var ACTIVITY = parseJSON('sdActivityData');
      var SCHEDULES= parseJSON('sdScheduleData');

      function staffById(id) { for (var i = 0; i < STAFF.length; i++) if (STAFF[i].id === id) return STAFF[i]; return null; }
      function escapeHtml(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
      function staffOptions(selectedId) {
        return ['<option value="">— Unassigned —</option>'].concat(STAFF.map(function (s) {
          return '<option value="' + s.id + '"' + (s.id === selectedId ? ' selected' : '') + '>' + escapeHtml(s.name) + '</option>';
        })).join('');
      }

      // ---- Per-stage counts --------------------------------------------------
      document.querySelectorAll('[data-stage-count]').forEach(function (el) {
        var s = el.getAttribute('data-stage-count');
        el.textContent = document.querySelectorAll('.sd-col[data-stage="' + s + '"] .sd-card').length;
      });

      // ---- Unassigned KPI ----------------------------------------------------
      var unassignedCount = TASKS.filter(function (t) { return !t.assigneeId && t.status !== 'Done'; }).length;
      var unassignedKpi = document.getElementById('sdUnassignedKpi');
      if (unassignedKpi) unassignedKpi.textContent = unassignedCount;

      // ---- Capacity-bar colour by load --------------------------------------
      document.querySelectorAll('.sd-capacity-bar > span[data-load]').forEach(function (bar) {
        var load = parseInt(bar.getAttribute('data-load'), 10) || 0;
        bar.classList.add(load >= 90 ? 'load-high' : load >= 70 ? 'load-mid' : 'load-low');
      });

      // ---- Countdown chips ---------------------------------------------------
      function today() { var d = new Date(); d.setHours(0,0,0,0); return d; }
      function fmtCountdown(dateStr) {
        if (!dateStr) return { text: '—', cls: '' };
        var d = new Date(dateStr + 'T00:00:00');
        if (isNaN(d.getTime())) return { text: dateStr, cls: '' };
        var diff = Math.round((d - today()) / 86400000);
        if (diff < 0)  return { text: Math.abs(diff) + 'd overdue', cls: 'overdue' };
        if (diff === 0) return { text: 'Today',          cls: 'due-soon' };
        if (diff === 1) return { text: 'Tomorrow',       cls: 'due-soon' };
        if (diff <= 3) return { text: 'in ' + diff + 'd', cls: 'due-soon' };
        return { text: 'in ' + diff + 'd', cls: '' };
      }
      document.querySelectorAll('.sd-countdown[data-countdown]').forEach(function (el) {
        var r = fmtCountdown(el.getAttribute('data-countdown'));
        el.textContent = el.getAttribute('data-countdown') + ' · ' + r.text;
        if (r.cls) el.classList.add(r.cls);
      });

      // ---- Reminder bell toggle on schedule cards ---------------------------
      document.querySelectorAll('.sd-schedule-card [data-act="reminder"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var on = !btn.classList.contains('on');
          btn.classList.toggle('on', on);
          btn.setAttribute('aria-pressed', on);
          btn.querySelector('span').innerHTML = on ? '&#128276;' : '&#128277;';
          var id = btn.getAttribute('data-schedule');
          var s = SCHEDULES.find(function (x) { return x.id === id; }); if (s) s.reminderOn = on;
        });
      });

      // ---- Snooze popover ---------------------------------------------------
      document.querySelectorAll('.sd-schedule-card [data-act="snooze"]').forEach(function (btn) {
        btn.addEventListener('click', function (ev) {
          ev.stopPropagation();
          var existing = document.querySelector('.sd-snooze-pop'); if (existing) existing.remove();
          var pop = document.createElement('div');
          pop.className = 'sd-snooze-pop';
          pop.innerHTML = '<strong>Snooze for</strong>' +
            '<button type="button" data-d="1">1 day</button>' +
            '<button type="button" data-d="3">3 days</button>' +
            '<button type="button" data-d="7">7 days</button>';
          btn.parentElement.appendChild(pop);
          pop.addEventListener('click', function (e) {
            var d = e.target.getAttribute && e.target.getAttribute('data-d');
            if (!d) return;
            var card = btn.closest('.sd-schedule-card');
            var cd   = card.querySelector('.sd-countdown');
            var base = new Date(card.getAttribute('data-nextrun') + 'T00:00:00');
            base.setDate(base.getDate() + parseInt(d, 10));
            var iso = base.toISOString().slice(0, 10);
            card.setAttribute('data-nextrun', iso);
            cd.classList.remove('overdue', 'due-soon');
            var r = fmtCountdown(iso);
            cd.textContent = iso + ' · ' + r.text;
            if (r.cls) cd.classList.add(r.cls);
            pop.remove();
          });
          document.addEventListener('click', function once(e) {
            if (!pop.contains(e.target) && e.target !== btn) { pop.remove(); document.removeEventListener('click', once); }
          });
        });
      });

      // ---- Reassign popover (schedule card) ---------------------------------
      document.querySelectorAll('.sd-schedule-card [data-act="reassign"]').forEach(function (btn) {
        btn.addEventListener('click', function (ev) {
          ev.stopPropagation();
          var existing = document.querySelector('.sd-snooze-pop'); if (existing) existing.remove();
          var card = btn.closest('.sd-schedule-card');
          var pop = document.createElement('div');
          pop.className = 'sd-snooze-pop';
          pop.innerHTML = '<strong>Reassign to</strong><select>' + staffOptions(card.getAttribute('data-assignee')) + '</select>';
          btn.parentElement.appendChild(pop);
          pop.querySelector('select').addEventListener('change', function (e) {
            var s = staffById(e.target.value);
            var holder = card.querySelector('.sd-sc-assignee');
            holder.innerHTML = s
              ? '<span class="sd-avatar" style="background:' + s.color + '">' + s.initials + '</span><span class="sd-assignee-name">' + escapeHtml(s.name) + '</span>'
              : '<span class="sd-avatar sd-avatar-unassigned">?</span><span class="sd-assignee-name muted">Unassigned</span>';
            card.setAttribute('data-assignee', s ? s.id : '');
            pop.remove();
          });
        });
      });

      // ---- Run-now schedule card -> open modal pre-filled -------------------
      document.querySelectorAll('.sd-schedule-card [data-act="run-now"]').forEach(function (btn) {
        btn.addEventListener('click', function () { openModal(btn.getAttribute('data-process')); });
      });

      // ---- Team assign list quick-assign ------------------------------------
      document.querySelectorAll('.sd-assign-select').forEach(function (sel) {
        sel.addEventListener('change', function () {
          var li = sel.closest('.sd-task');
          var opt = sel.options[sel.selectedIndex];
          var name = opt.getAttribute('data-name') || '';
          var taskId = sel.getAttribute('data-task');
          var t = TASKS.find(function (x) { return x.id === taskId; });
          if (t) { t.assigneeId = sel.value; t.assigneeName = name; }
          if (sel.value) {
            li.classList.remove('is-unassigned');
            // refresh KPI
            var n = TASKS.filter(function (x) { return !x.assigneeId && x.status !== 'Done'; }).length;
            if (unassignedKpi) unassignedKpi.textContent = n;
          }
          // toast
          var toast = document.createElement('div');
          toast.className = 'sd-toast';
          toast.textContent = name ? ('Task assigned to ' + name) : 'Task unassigned';
          document.body.appendChild(toast);
          setTimeout(function () { toast.remove(); }, 1800);
        });
      });

      // ---- Row assignee select on engagements table -------------------------
      document.querySelectorAll('.sd-row-assign').forEach(function (sel) {
        sel.addEventListener('change', function () {
          var toast = document.createElement('div');
          toast.className = 'sd-toast';
          toast.textContent = 'Engagement reassigned to ' + sel.options[sel.selectedIndex].text;
          document.body.appendChild(toast);
          setTimeout(function () { toast.remove(); }, 1800);
        });
      });

      // ---- Table filters ----------------------------------------------------
      var f  = document.getElementById('sdFilter');
      var st = document.getElementById('sdStage');
      var ss = document.getElementById('sdStatus');
      function apply() {
        var q  = (f  && f.value  || '').toLowerCase();
        var vs = (st && st.value || '');
        var vu = (ss && ss.value || '');
        document.querySelectorAll('.sd-table tbody tr').forEach(function (tr) {
          var txt = tr.textContent.toLowerCase();
          var passQ = !q  || txt.indexOf(q) !== -1;
          var passS = !vs || tr.getAttribute('data-stage')  === vs;
          var passU = !vu || tr.getAttribute('data-status') === vu;
          tr.style.display = (passQ && passS && passU) ? '' : 'none';
        });
      }
      [f, st, ss].forEach(function (el) { if (el) el.addEventListener('input', apply); });

      // ---- Drawer + tabs ----------------------------------------------------
      var drawer        = document.getElementById('sdDrawer');
      var drawerTitle   = document.getElementById('sdDrawerTitle');
      var panelChk      = document.getElementById('sdPanelChecklist');
      var panelAct      = document.getElementById('sdPanelActivity');
      var panelSched    = document.getElementById('sdPanelSchedule');
      var activityBadge = document.getElementById('sdActivityBadge');
      var currentEng    = null;

      function switchTab(name) {
        document.querySelectorAll('.sd-tab').forEach(function (b) {
          var active = b.getAttribute('data-tab') === name;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-selected', active);
        });
        document.querySelectorAll('.sd-tab-panel').forEach(function (p) {
          p.classList.toggle('is-active', p.getAttribute('data-panel') === name);
        });
      }
      document.querySelectorAll('.sd-tab').forEach(function (b) {
        b.addEventListener('click', function () { switchTab(b.getAttribute('data-tab')); });
      });

      function renderChecklist(engId) {
        var rows = TASKS.filter(function (t) { return t.engagementId === engId; });
        if (rows.length === 0) {
          panelChk.innerHTML = '<p class="muted">No tasks yet.</p><button type="button" class="btn btn-link" id="sdAddTaskBtn">+ Add task</button>';
        } else {
          var body = rows.map(function (t) {
            var s = staffById(t.assigneeId);
            var avatar = s ? '<span class="sd-avatar sd-avatar-sm" style="background:' + s.color + '">' + s.initials + '</span>' : '<span class="sd-avatar sd-avatar-sm sd-avatar-unassigned">?</span>';
            return '<tr data-task="' + t.id + '">' +
              '<td><label class="sd-chk"><input type="checkbox" ' + (t.status === 'Done' ? 'checked' : '') + ' data-task-status="' + t.id + '"> ' + escapeHtml(t.name) + '</label></td>' +
              '<td class="sd-assignee-cell">' + avatar + ' <select class="sd-task-assign" data-task="' + t.id + '">' + staffOptions(t.assigneeId) + '</select></td>' +
              '<td><input type="date" class="sd-task-due" data-task="' + t.id + '" value="' + escapeHtml(t.due) + '"></td>' +
              '<td><span class="badge badge-' + t.status.toLowerCase().replace(/ /g,'-') + '">' + escapeHtml(t.status) + '</span></td>' +
              '<td><button type="button" class="sd-bell sd-bell-sm ' + (t.reminderOn ? 'on' : '') + '" data-task-reminder="' + t.id + '" aria-pressed="' + t.reminderOn + '" title="Toggle reminder"><span>' + (t.reminderOn ? '&#128276;' : '&#128277;') + '</span></button></td>' +
            '</tr>';
          }).join('');
          panelChk.innerHTML =
            '<table class="sd-table sd-checklist-table"><thead><tr><th>Task</th><th>Assignee</th><th>Due</th><th>Status</th><th></th></tr></thead><tbody>' + body + '</tbody></table>' +
            '<div class="sd-checklist-actions"><button type="button" class="btn btn-link" id="sdAddTaskBtn">+ Add task</button></div>';
        }
        // Wire checklist controls
        panelChk.querySelectorAll('[data-task-status]').forEach(function (cb) {
          cb.addEventListener('change', function () {
            var id = cb.getAttribute('data-task-status');
            var t = TASKS.find(function (x) { return x.id === id; });
            if (t) t.status = cb.checked ? 'Done' : 'In Progress';
            var badge = cb.closest('tr').querySelector('.badge');
            badge.className = 'badge badge-' + t.status.toLowerCase().replace(/ /g,'-');
            badge.textContent = t.status;
          });
        });
        panelChk.querySelectorAll('.sd-task-assign').forEach(function (sel) {
          sel.addEventListener('change', function () {
            var id = sel.getAttribute('data-task');
            var t = TASKS.find(function (x) { return x.id === id; });
            var s = staffById(sel.value);
            if (t) { t.assigneeId = sel.value; t.assigneeName = s ? s.name : ''; }
            var av = sel.parentElement.querySelector('.sd-avatar');
            if (s) { av.style.background = s.color; av.textContent = s.initials; av.classList.remove('sd-avatar-unassigned'); }
            else   { av.style.background = ''; av.textContent = '?'; av.classList.add('sd-avatar-unassigned'); }
            postActivity(currentEng, 'system', 'Task reassigned to ' + (s ? s.name : 'Unassigned') + '.');
          });
        });
        panelChk.querySelectorAll('[data-task-reminder]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var id = btn.getAttribute('data-task-reminder');
            var t = TASKS.find(function (x) { return x.id === id; });
            var on = !btn.classList.contains('on');
            btn.classList.toggle('on', on);
            btn.setAttribute('aria-pressed', on);
            btn.querySelector('span').innerHTML = on ? '&#128276;' : '&#128277;';
            if (t) t.reminderOn = on;
          });
        });
        var addBtn = panelChk.querySelector('#sdAddTaskBtn');
        if (addBtn) addBtn.addEventListener('click', function () {
          var name = prompt('Task name?'); if (!name) return;
          var newTask = { id: 'tsk-' + Date.now(), engagementId: currentEng, name: name, assigneeId: '', assigneeName: '', due: new Date(Date.now() + 86400000 * 3).toISOString().slice(0,10), status: 'Not Started', reminderOn: true };
          TASKS.push(newTask);
          renderChecklist(currentEng);
          postActivity(currentEng, 'system', 'Task added: ' + name);
        });
      }

      function renderActivity(engId) {
        var rows = ACTIVITY.filter(function (a) { return a.engagementId === engId; })
                           .sort(function (a, b) { return b.ts.localeCompare(a.ts); });
        activityBadge.textContent = rows.length;
        var feed = rows.map(function (a) {
          var text = escapeHtml(a.text).replace(/@([A-Za-z][\w ]+?)(?=$|[,.;:!?]|\s{2}|\s+@|\s+please|\s+can|$)/g, '<span class="sd-mention">@$1</span>');
          return '<li class="sd-act sd-act-' + a.type + '">' +
            '<div class="sd-act-meta"><strong>' + escapeHtml(a.actor) + '</strong> <span class="muted">· ' + escapeHtml(a.ts) + '</span></div>' +
            '<div class="sd-act-text">' + text + '</div>' +
          '</li>';
        }).join('') || '<li class="muted">No activity yet.</li>';
        panelAct.innerHTML =
          '<ul class="sd-activity">' + feed + '</ul>' +
          '<div class="sd-composer">' +
            '<textarea id="sdCommentText" placeholder="Add a comment. Use @ to mention a teammate."></textarea>' +
            '<div class="sd-mention-list" id="sdMentionList" hidden></div>' +
            '<div class="sd-composer-actions">' +
              '<span class="muted">Use @ to mention</span>' +
              '<button type="button" class="btn btn-primary" id="sdPostComment">Post comment</button>' +
            '</div>' +
          '</div>';
        wireComposer();
      }

      function wireComposer() {
        var ta = document.getElementById('sdCommentText');
        var list = document.getElementById('sdMentionList');
        var post = document.getElementById('sdPostComment');
        if (!ta) return;
        ta.addEventListener('input', function () {
          var v = ta.value;
          var atIdx = v.lastIndexOf('@');
          if (atIdx < 0 || (atIdx > 0 && /\S/.test(v[atIdx - 1]))) { list.hidden = true; return; }
          var q = v.slice(atIdx + 1).toLowerCase();
          if (/\s/.test(q)) { list.hidden = true; return; }
          var matches = STAFF.filter(function (s) { return s.name.toLowerCase().indexOf(q) !== -1; });
          if (!matches.length) { list.hidden = true; return; }
          list.innerHTML = matches.map(function (s) {
            return '<button type="button" data-name="' + escapeHtml(s.name) + '"><span class="sd-avatar sd-avatar-sm" style="background:' + s.color + '">' + s.initials + '</span> ' + escapeHtml(s.name) + '</button>';
          }).join('');
          list.hidden = false;
        });
        list.addEventListener('click', function (e) {
          var btn = e.target.closest('button[data-name]'); if (!btn) return;
          var v = ta.value;
          var atIdx = v.lastIndexOf('@');
          ta.value = v.slice(0, atIdx) + '@' + btn.getAttribute('data-name') + ' ';
          list.hidden = true;
          ta.focus();
        });
        post.addEventListener('click', function () {
          var text = (ta.value || '').trim(); if (!text) return;
          postActivity(currentEng, 'You', text, 'comment');
          ta.value = '';
        });
      }

      function postActivity(engId, actor, text, type) {
        var entry = { id: 'act-' + Date.now(), engagementId: engId, type: type || 'status', actor: actor, ts: new Date().toISOString().slice(0,16).replace('T',' '), text: text };
        ACTIVITY.unshift(entry);
        if (engId === currentEng) renderActivity(engId);
      }

      function renderSchedule(engId) {
        // Find any schedule whose processId matches this engagement's process.
        var row = document.querySelector('.sd-table tbody tr[data-eng="' + engId + '"]');
        var procName = row ? (row.querySelector('.sd-open') || {}).textContent : '';
        var existing = SCHEDULES.find(function (s) { return s.processName === procName; });
        panelSched.innerHTML =
          '<form class="sd-sched-form" id="sdSchedForm">' +
            '<label>Recurrence' +
              '<div class="sd-radio-row">' +
                '<label><input type="radio" name="rec" value="None"' + (!existing ? ' checked' : '') + '> None</label>' +
                '<label><input type="radio" name="rec" value="Daily"' + (existing && /daily/i.test(existing.recurrence) ? ' checked' : '') + '> Daily</label>' +
                '<label><input type="radio" name="rec" value="Weekly"' + (existing && /weekly/i.test(existing.recurrence) ? ' checked' : '') + '> Weekly</label>' +
                '<label><input type="radio" name="rec" value="Monthly"' + (existing && /monthly/i.test(existing.recurrence) ? ' checked' : '') + '> Monthly</label>' +
              '</div>' +
            '</label>' +
            '<label>Day' +
              '<input type="text" name="day" placeholder="e.g. 20 / Fri" value="' + escapeHtml(existing ? (existing.recurrence.split('·')[1] || '').trim() : '') + '">' +
            '</label>' +
            '<label>Next run' +
              '<input type="date" name="nextrun" value="' + escapeHtml(existing ? existing.nextRun : '') + '">' +
            '</label>' +
            '<label>Reminder lead-time' +
              '<select name="lead">' +
                '<option value="1">1 day before</option>' +
                '<option value="3" selected>3 days before</option>' +
                '<option value="7">7 days before</option>' +
              '</select>' +
            '</label>' +
            '<div class="sd-sched-actions">' +
              '<button type="button" class="btn btn-primary" id="sdSchedSave">Save schedule</button>' +
            '</div>' +
          '</form>';
        document.getElementById('sdSchedSave').addEventListener('click', function () {
          var toast = document.createElement('div');
          toast.className = 'sd-toast';
          toast.textContent = 'Schedule saved (stub).';
          document.body.appendChild(toast);
          setTimeout(function () { toast.remove(); }, 1800);
          postActivity(engId, 'system', 'Schedule updated.');
        });
      }

      function openDrawer(engId, title) {
        currentEng = engId;
        drawerTitle.textContent = title || ('Engagement ' + engId);
        switchTab('checklist');
        renderChecklist(engId);
        renderActivity(engId);
        renderSchedule(engId);
        drawer.hidden = false;
      }
      document.getElementById('sdDrawerClose').addEventListener('click', function () {
        drawer.hidden = true;
      });
      document.querySelectorAll('.sd-open, .sd-card[data-eng]').forEach(function (el) {
        el.addEventListener('click', function (ev) {
          ev.preventDefault();
          var id = el.getAttribute('data-eng');
          var title = el.textContent.trim() || ('Engagement ' + id);
          openDrawer(id, title);
        });
      });

      // ---- Row action buttons -----------------------------------------------
      document.querySelectorAll('.sd-table [data-act]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var act = btn.getAttribute('data-act');
          var id  = btn.getAttribute('data-eng');
          if (act === 'open')    openDrawer(id);
          if (act === 'advance') { postActivity(id, 'system', 'Engagement advanced to next stage.'); alert('Engagement ' + id + ' advanced (stub).'); }
          if (act === 'cancel') {
            if (!confirm('Cancel engagement ' + id + '?')) return;
            var row = btn.closest('tr');
            if (row) { row.style.opacity = .5; row.setAttribute('data-stage','Cancelled'); }
          }
        });
      });

      // ---- Modal: Catalog start + toolbar new + schedule "Run now" ----------
      var modal = document.getElementById('sdModal');
      function openModal(processId) {
        if (!modal) return;
        if (processId) {
          var sel = document.getElementById('sdModalProcess');
          if (sel) sel.value = processId;
        }
        modal.hidden = false;
      }
      function closeModal() { if (modal) modal.hidden = true; }
      document.querySelectorAll('.sd-start').forEach(function (b) {
        b.addEventListener('click', function () { openModal(b.getAttribute('data-process')); });
      });
      var newBtn = document.getElementById('sdNew');
      if (newBtn) newBtn.addEventListener('click', function () { openModal(); });
      var newSched = document.getElementById('sdNewSchedule');
      if (newSched) newSched.addEventListener('click', function () { alert('New schedule (stub). Open an engagement and use the Schedule tab.'); });
      var cancelBtn = document.getElementById('sdModalCancel');
      if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
      var form = document.getElementById('sdModalForm');
      if (form) form.addEventListener('submit', function (ev) {
        if (location.hostname === '127.0.0.1' || location.hostname === 'localhost') {
          ev.preventDefault();
          alert('Preview: new engagement created (stub). Wire Flow_StartEngagement in production.');
          closeModal();
        }
      });
    })();
  </script>
</section>

<style>
  .service-delivery .sd-header { margin-bottom: 18px; }
  .service-delivery .sd-meta   { color: #6b7280; margin: 4px 0 0; font-size: 14px; }

  .service-delivery .kpi-grid  { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 22px; }
  .service-delivery .kpi       { background: #f7f9fc; border: 1px solid #e1e6ec; border-radius: 8px; padding: 12px 14px; }
  .service-delivery .kpi.kpi-warn { background: #fff8ea; border-color: #f5d597; }
  .service-delivery .kpi-label { display: block; color: #6b7280; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; }
  .service-delivery .kpi strong{ font-size: 22px; color: #00395E; display: block; margin-top: 4px; }

  .service-delivery .sd-pipeline-wrap { margin: 0 0 28px; }
  .service-delivery .sd-pipeline { display: grid; grid-template-columns: repeat(5, minmax(180px, 1fr)); gap: 10px; }
  .service-delivery .sd-col      { background: #f7f9fc; border: 1px solid #e1e6ec; border-radius: 8px; padding: 8px; min-height: 80px; }
