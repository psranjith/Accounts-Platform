{% include 'adp-user-context' %}
{% assign nav_key = 'team' %}
{% assign page_title = 'Team' %}
{% assign breadcrumbs = 'Dashboard|/dashboard · Team' %}
{% assign is_operator   = false %}
{% assign is_firmadmin  = false %}
{% assign is_accountant = false %}
{% assign is_client     = false %}
{% if adp_personagroup == 'operator'   %}{% assign is_operator   = true %}{% endif %}
{% if adp_personagroup == 'firmadmin'  %}{% assign is_firmadmin  = true %}{% endif %}
{% if adp_personagroup == 'accountant' %}{% assign is_accountant = true %}{% endif %}
{% if adp_personagroup == 'client'     %}{% assign is_client     = true %}{% endif %}
{% assign can_manage_team = false %}
{% if is_firmadmin or is_operator %}{% assign can_manage_team = true %}{% endif %}
{% if can_manage_team %}{% assign page_actions = '<a href="#invite" class="btn btn-primary" id="teamInviteBtn">+ Invite teammate</a>' %}{% endif %}
{% include 'adp-shell-open' %}

{% unless can_manage_team %}
  <div class="placeholder" style="padding:18px;text-align:center;color:#6b7280;background:#f7f9fc;border:1px dashed #cbd5e1;border-radius:6px">Team management is available to firm admins. Ask your firm admin to invite or change roles.</div>
  {% include 'adp-shell-close' %}
{% else %}

{% comment %}
  Team
  -----
  Firm Admin user management: invite teammates, assign clients, change role,
  disable. Operator can also view (read-only across firms) when impersonating.
  Tabs: Active · Pending invites · Disabled · + Invite.
{% endcomment %}

{% fetchxml team_q %}
<fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="200">
  <entity name="adp_appuser">
    <attribute name="adp_appuserid" />
    <attribute name="adp_name" />
    <attribute name="adp_email" />
    <attribute name="adp_jobfunction" />
    <attribute name="adp_role" />
    <attribute name="adp_status" />
    <attribute name="adp_invitedon" />
    <attribute name="adp_lastloginon" />
    <attribute name="adp_firmid" />
    <order attribute="adp_name" />
    {% unless is_operator %}
    <filter type="and">
      <condition attribute="adp_firmid" operator="eq" value="{{ adp_firmid }}" />
    </filter>
    {% endunless %}
  </entity>
</fetch>
{% endfetchxml %}
{% assign team = team_q.results.entities %}

{% assign active_count = 0 %}
{% assign pending_count = 0 %}
{% assign disabled_count = 0 %}
{% for u in team %}
  {% if u.adp_status == 'Active' %}{% assign active_count = active_count | plus: 1 %}{% endif %}
  {% if u.adp_status == 'Pending' %}{% assign pending_count = pending_count | plus: 1 %}{% endif %}
  {% if u.adp_status == 'Disabled' %}{% assign disabled_count = disabled_count | plus: 1 %}{% endif %}
{% endfor %}

<div class="cl-kpis">
  <div class="cl-kpi"><span>Active</span><strong>{{ active_count }}</strong><small>can sign in today</small></div>
  <div class="cl-kpi"><span>Pending invites</span><strong>{{ pending_count }}</strong><small>not yet accepted</small></div>
  <div class="cl-kpi"><span>Disabled</span><strong>{{ disabled_count }}</strong><small>retained for audit</small></div>
  <div class="cl-kpi"><span>Firm admins</span><strong>{% assign fa_count = 0 %}{% for u in team %}{% if u.adp_jobfunction == 'firmadmin' and u.adp_status != 'Disabled' %}{% assign fa_count = fa_count | plus: 1 %}{% endif %}{% endfor %}{{ fa_count }}</strong><small>have full firm access</small></div>
</div>

<nav class="cl-tabs" role="tablist">
  <a class="cl-tab is-active" href="#active"  data-tab="active">Active</a>
  <a class="cl-tab"           href="#pending" data-tab="pending">Pending invites</a>
  <a class="cl-tab"           href="#disabled" data-tab="disabled">Disabled</a>
  <a class="cl-tab"           href="#invite"  data-tab="invite">+ Invite teammate</a>
</nav>

<section class="cl-panel is-active" data-panel="active">
  <div class="cl-toolbar">
    <input class="cl-search" type="search" placeholder="Search name or email…" id="teamSearch" />
    <select class="cl-filter" id="teamRoleFilter">
      <option value="">All roles</option>
      <option value="firmadmin">Firm admins</option>
      <option value="accountant">Accountants</option>
      <option value="client">Clients</option>
    </select>
  </div>
  <table class="table cl-table">
    <thead><tr><th>Member</th><th>Role</th><th>Clients</th><th>Last sign-in</th><th></th></tr></thead>
    <tbody id="teamBody">
      {% for u in team %}{% if u.adp_status == 'Active' %}
      <tr data-name="{{ u.adp_name | downcase }} {{ u.adp_email | downcase }}" data-role="{{ u.adp_jobfunction }}">
        <td><strong>{{ u.adp_name }}</strong><br/><small class="muted">{{ u.adp_email }}</small></td>
        <td><span class="badge badge-bundle">{{ u.adp_role }}</span></td>
        <td>{% if u.adp_jobfunction == 'firmadmin' %}All firm clients{% else %}<a href="/clients?member={{ u.adp_appuserid }}">Assigned</a>{% endif %}</td>
        <td>{% if u.adp_lastloginon %}{{ u.adp_lastloginon | date: '%d %b %Y' }}{% else %}<span class="muted">—</span>{% endif %}</td>
        <td>
          <a class="btn btn-link" href="#edit-{{ u.adp_appuserid }}" data-action="edit" data-id="{{ u.adp_appuserid }}">Edit</a>
          <a class="btn btn-link btn-danger" href="#disable-{{ u.adp_appuserid }}" data-action="disable" data-id="{{ u.adp_appuserid }}" data-name="{{ u.adp_name }}">Disable</a>
        </td>
      </tr>
      {% endif %}{% endfor %}
    </tbody>
  </table>
</section>

<section class="cl-panel" data-panel="pending">
  <table class="table cl-table">
    <thead><tr><th>Invitee</th><th>Role</th><th>Invited</th><th></th></tr></thead>
    <tbody>
      {% for u in team %}{% if u.adp_status == 'Pending' %}
      <tr>
        <td><strong>{{ u.adp_name }}</strong><br/><small class="muted">{{ u.adp_email }}</small></td>
        <td>{{ u.adp_role }}</td>
        <td>{% if u.adp_invitedon %}{{ u.adp_invitedon | date: '%d %b %Y' }}{% else %}<span class="muted">—</span>{% endif %}</td>
        <td>
          <a class="btn btn-link" href="#resend-{{ u.adp_appuserid }}" data-action="resend" data-id="{{ u.adp_appuserid }}">Resend</a>
          <a class="btn btn-link btn-danger" href="#cancel-{{ u.adp_appuserid }}" data-action="cancel" data-id="{{ u.adp_appuserid }}">Cancel</a>
        </td>
      </tr>
      {% endif %}{% endfor %}
      {% if pending_count == 0 %}<tr><td colspan="4" class="muted small">No pending invites.</td></tr>{% endif %}
    </tbody>
  </table>
</section>

<section class="cl-panel" data-panel="disabled">
  <table class="table cl-table">
    <thead><tr><th>Member</th><th>Role</th><th>Disabled</th><th></th></tr></thead>
    <tbody>
      {% for u in team %}{% if u.adp_status == 'Disabled' %}
      <tr>
        <td><strong>{{ u.adp_name }}</strong><br/><small class="muted">{{ u.adp_email }}</small></td>
        <td>{{ u.adp_role }}</td>
        <td>{% if u.adp_disabledon %}{{ u.adp_disabledon | date: '%d %b %Y' }}{% else %}<span class="muted">—</span>{% endif %}</td>
        <td><a class="btn btn-link" href="#reactivate-{{ u.adp_appuserid }}" data-action="reactivate" data-id="{{ u.adp_appuserid }}">Reactivate</a></td>
      </tr>
      {% endif %}{% endfor %}
      {% if disabled_count == 0 %}<tr><td colspan="4" class="muted small">No disabled members.</td></tr>{% endif %}
    </tbody>
  </table>
</section>

<section class="cl-panel" data-panel="invite">
  <div class="cl-onboard">
    <h3>Invite a teammate</h3>
    <p class="muted">An Entra B2B guest invitation is sent. They sign in with their work email and land on their persona dashboard.</p>
    <form class="cl-form" id="teamInviteForm" onsubmit="event.preventDefault(); ADPInviteTeammate(this);">
      <label>Full name<input type="text" name="displayName" required placeholder="e.g. Priya Menon" /></label>
      <label>Work email<input type="email" name="email" required placeholder="name@firm.com" /></label>
      <label>Job function
        <select name="jobFunction" required id="teamJobFunction">
          <option value="firmadmin">Firm admin (full firm access)</option>
          <option value="accountant" selected>Accountant</option>
          <option value="client">Client contact</option>
        </select>
      </label>
      <label>Role (web role to assign)
        <select name="role" required id="teamRoleSelect">
          <option value="ADP Firm Admin">ADP Firm Admin</option>
          <option value="ADP Accountant" selected>ADP Accountant</option>
          <option value="ADP Client User">ADP Client User</option>
        </select>
      </label>
      <label class="cl-form-full">Assign clients
        <small class="muted small">Required for accountants and clients. Firm admins get all firm clients automatically.</small>
        <select name="companyAssignments" multiple size="5" id="teamCompanies">
          {% fetchxml firm_companies_q %}
          <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="200">
            <entity name="adp_company">
              <attribute name="adp_companyid" />
              <attribute name="adp_name" />
              <order attribute="adp_name" />
              {% unless is_operator %}
              <filter type="and">
                <condition attribute="adp_firmid" operator="eq" value="{{ adp_firmid }}" />
              </filter>
              {% endunless %}
            </entity>
          </fetch>
          {% endfetchxml %}
          {% for c in firm_companies_q.results.entities %}
          <option value="{{ c.adp_companyid }}">{{ c.adp_name }}</option>
          {% endfor %}
        </select>
      </label>
      <div class="cl-form-actions">
        <button class="btn btn-default" type="reset">Reset</button>
        <button class="btn btn-primary" type="submit">Send invite</button>
      </div>
    </form>
  </div>
</section>

<script>
(function () {
  function activate(hash) {
    var name = (hash || '').replace('#','') || 'active';
    document.querySelectorAll('.cl-tab').forEach(function(a){ a.classList.toggle('is-active', a.getAttribute('data-tab') === name); });
    document.querySelectorAll('.cl-panel').forEach(function(p){ p.classList.toggle('is-active', p.getAttribute('data-panel') === name); });
  }
  document.querySelectorAll('.cl-tab').forEach(function(a){
    a.addEventListener('click', function(e){ e.preventDefault(); history.replaceState(null,'',a.getAttribute('href')); activate(a.getAttribute('href')); });
  });
  var btn = document.getElementById('teamInviteBtn');
  if (btn) btn.addEventListener('click', function(e){ e.preventDefault(); history.replaceState(null,'','#invite'); activate('#invite'); });

  var jf = document.getElementById('teamJobFunction');
  var rs = document.getElementById('teamRoleSelect');
  if (jf && rs) {
    var map = { firmadmin: 'ADP Firm Admin', accountant: 'ADP Accountant', client: 'ADP Client User' };
    jf.addEventListener('change', function(){ if (map[jf.value]) rs.value = map[jf.value]; });
  }

  var s = document.getElementById('teamSearch');
  var rf = document.getElementById('teamRoleFilter');
  function applyFilter(){
    var q = (s && s.value || '').toLowerCase();
    var role = rf && rf.value || '';
    document.querySelectorAll('#teamBody tr').forEach(function(tr){
      var matchText = tr.getAttribute('data-name').indexOf(q) !== -1;
      var matchRole = !role || tr.getAttribute('data-role') === role;
      tr.style.display = (matchText && matchRole) ? '' : 'none';
    });
  }
  if (s)  s.addEventListener('input', applyFilter);
  if (rf) rf.addEventListener('change', applyFilter);

  document.querySelectorAll('[data-action]').forEach(function(a){
    a.addEventListener('click', function(e){
      e.preventDefault();
      var act = a.getAttribute('data-action');
      var id = a.getAttribute('data-id');
      if (act === 'disable') {
        var name = a.getAttribute('data-name') || 'this member';
        if (!confirm('Disable ' + name + '? Their sessions are revoked immediately. Records are retained for audit.')) return;
      }
      if (typeof window.ADPTeamAction === 'function') {
        window.ADPTeamAction(act, id);
      } else {
        alert(act + ' ' + id + ' (preview)');
      }
    });
  });

  window.ADPInviteTeammate = window.ADPInviteTeammate || function (form) {
    var fd = new FormData(form);
    var payload = {
      email: fd.get('email'),
      displayName: fd.get('displayName'),
      jobFunction: fd.get('jobFunction'),
      role: fd.get('role'),
      companyAssignments: Array.from(form.companyAssignments.selectedOptions || []).map(function(o){ return { companyId: o.value, accessLevel: 'contribute' }; })
    };
    alert('Invite sent (preview):\n' + JSON.stringify(payload, null, 2));
    form.reset();
  };

  activate(location.hash);
})();
</script>

<style>
  .cl-kpis { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:10px; margin-bottom:16px; }
  .cl-kpi { background:#fff; border:1px solid #e1e6ec; border-radius:8px; padding:10px 12px; }
  .cl-kpi span { display:block; font-size:11px; text-transform:uppercase; letter-spacing:.04em; color:#6b7280; }
  .cl-kpi strong { display:block; font-size:24px; color:#00395E; margin:2px 0; }
  .cl-kpi small { color:#6b7280; }
  .cl-tabs { display:flex; gap:2px; border-bottom:1px solid #e1e6ec; margin-bottom:12px; flex-wrap:wrap; }
  .cl-tab { padding:8px 14px; text-decoration:none; color:#6b7280; font-weight:600; font-size:13px; border-bottom:2px solid transparent; }
  .cl-tab.is-active { color:#00395E; border-bottom-color:#00A8E8; }
  .cl-panel { display:none; }
  .cl-panel.is-active { display:block; }
  .cl-toolbar { display:flex; gap:8px; margin-bottom:10px; flex-wrap:wrap; }
  .cl-search { flex:1 1 220px; padding:7px 10px; border:1px solid #e1e6ec; border-radius:6px; }
  .cl-filter { padding:7px 10px; border:1px solid #e1e6ec; border-radius:6px; background:#fff; }
  .badge-bundle { background:#e1f0ff; color:#003b66; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; }
  .btn-danger { color:#c63a3a; }
  .cl-onboard { background:#fff; border:1px solid #e1e6ec; border-radius:8px; padding:16px; max-width:780px; }
  .cl-onboard h3 { margin-top:0; color:#00395E; }
  .cl-form { display:grid; grid-template-columns:1fr 1fr; gap:10px 14px; margin-top:8px; }
  .cl-form label { display:flex; flex-direction:column; font-size:12px; color:#374151; font-weight:600; }
  .cl-form input, .cl-form select, .cl-form textarea { margin-top:4px; padding:7px 10px; border:1px solid #e1e6ec; border-radius:6px; font-size:14px; font-weight:400; }
  .cl-form-full { grid-column:1 / -1; }
  .cl-form-actions { grid-column:1 / -1; display:flex; gap:8px; justify-content:flex-end; }
  .muted { color:#6b7280; }
  .small { font-size:12px; }
  @media (max-width: 720px) { .cl-form { grid-template-columns:1fr; } }
</style>

{% include 'adp-shell-close' %}
{% endunless %}
