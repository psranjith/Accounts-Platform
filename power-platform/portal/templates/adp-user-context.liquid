{% assign adp_companyid = adp_companyid | default: '' %}
{% assign adp_role = adp_role | default: '' %}
{% assign adp_sharepointsiteurl = adp_sharepointsiteurl | default: '' %}
{% assign adp_powerbi_workspaceid = adp_powerbi_workspaceid | default: '03623be0-6e17-43ba-9fe5-947e9b67c823' %}
{% assign adp_powerbi_reportid = adp_powerbi_reportid | default: '' %}
{% assign adp_copilot_botid = adp_copilot_botid | default: '' %}
{% assign adp_copilot_tenantid = adp_copilot_tenantid | default: '' %}
{% assign adp_copilot_token_endpoint = adp_copilot_token_endpoint | default: '' %}
{% assign adp_rdpfunctionbaseurl = adp_rdpfunctionbaseurl | default: '' %}
{% assign adp_rdpfunctionkey = adp_rdpfunctionkey | default: '' %}
{% assign adp_firmname = adp_firmname | default: '' %}
{% assign adp_firmid = adp_firmid | default: '' %}
{% assign adp_personagroup = adp_personagroup | default: '' %}

{% if user.id %}
  {% fetchxml userctx %}
  <fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false" top="1">
    <entity name="adp_appuser">
      <attribute name="adp_companyid" />
      <attribute name="adp_role" />
      <filter>
        <condition attribute="adp_entraobjectid" operator="eq" value="{{ user.identity_provider_object_id }}" />
      </filter>
      <link-entity name="adp_company" from="adp_companyid" to="adp_companyid" alias="company">
        <attribute name="adp_sharepointsiteurl" />
      </link-entity>
    </entity>
  </fetch>
  {% endfetchxml %}

  {% if userctx.results.entities.size > 0 %}
    {% assign u = userctx.results.entities[0] %}
    {% assign adp_companyid = u.adp_companyid.id %}
    {% assign adp_role = u.adp_role.label %}
    {% assign adp_sharepointsiteurl = u['company.adp_sharepointsiteurl'] %}
  {% endif %}
{% endif %}

{% comment %}
  Derive persona group from role label so the shell can render the right nav
  without each page having to know about all role labels.
  Roles today: 'ADP Admin', 'ADP Accountant', 'ADP Client User'.
  New (preview only): 'Smartsoft Operator', 'Firm Admin'.
{% endcomment %}
{% if adp_personagroup == '' %}
  {% assign __r = adp_role | downcase %}
  {% if __r contains 'operator' or __r contains 'smartsoft' %}{% assign adp_personagroup = 'operator' %}
  {% elsif __r contains 'firm admin' or __r contains 'firmadmin' %}{% assign adp_personagroup = 'firmadmin' %}
  {% elsif __r contains 'admin' %}{% assign adp_personagroup = 'firmadmin' %}
  {% elsif __r contains 'accountant' %}{% assign adp_personagroup = 'accountant' %}
  {% elsif __r contains 'client' %}{% assign adp_personagroup = 'client' %}
  {% else %}{% assign adp_personagroup = 'client' %}
  {% endif %}
{% endif %}

{% if adp_firmname == '' %}{% assign adp_firmname = 'Smartsoft Books LLP' %}{% endif %}
